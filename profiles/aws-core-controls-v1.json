{
  "profile_id": "aws-core-controls-v1",
  "profile_version": "1.0.0",
  "name": "AWS Core Controls",
  "description": "Basic security checks for AWS infrastructure: IAM, RDS, S3, CloudTrail.",
  "rules": [
    {
      "id": "iam.mfa_enforced",
      "description": "MFA is enforced for all IAM users",
      "path": "iam.mfa_enabled",
      "expected": true
    },
    {
      "id": "iam.root_access_key_disabled",
      "description": "Root account access keys are disabled",
      "path": "iam.root_access_key_active",
      "expected": false
    },
    {
      "id": "iam.password_policy_min_length",
      "description": "Password minimum length is at least 14 characters",
      "path": "iam.password_policy.minimum_length",
      "operator": "gte",
      "expected": 14
    },
    {
      "id": "rds.encryption_at_rest",
      "description": "RDS storage encryption is enabled",
      "path": "rds.storage_encrypted",
      "expected": true
    },
    {
      "id": "rds.public_access_disabled",
      "description": "RDS instances are not publicly accessible",
      "path": "rds.publicly_accessible",
      "expected": false
    },
    {
      "id": "s3.public_access_blocked",
      "description": "S3 public access block is enabled",
      "path": "s3.public_access_blocked",
      "expected": true
    },
    {
      "id": "s3.versioning_enabled",
      "description": "S3 versioning is enabled on primary bucket",
      "path": "s3.versioning",
      "expected": true
    },
    {
      "id": "cloudtrail.enabled",
      "description": "CloudTrail is enabled",
      "path": "cloudtrail.is_logging",
      "expected": true
    },
    {
      "id": "cloudtrail.multi_region",
      "description": "CloudTrail is multi-region",
      "path": "cloudtrail.is_multi_region",
      "expected": true
    },
    {
      "id": "vpc.flow_logs_enabled",
      "description": "VPC flow logs are enabled",
      "path": "vpc.flow_logs_enabled",
      "expected": true
    }
  ]
}
